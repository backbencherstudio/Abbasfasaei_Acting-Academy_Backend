// updated
model PaymentTransaction {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  transaction_ref String @unique

  user_id  String
  order_id String

  installment_id String?

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("USD")

  status  PaymentTransactionStatus @default(PENDING)
  gateway PaymentGateway           @default(STRIPE)

  payment_method String?
  card_last4     String?
  receipt_url    String?

  stripe_payment_intent_id   String? @unique
  stripe_charge_id           String? @unique
  stripe_checkout_session_id String? @unique

  metadata Json?

  paid_at DateTime?

  user        User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  order       Order        @relation(fields: [order_id], references: [id], onDelete: Cascade)
  installment Installment? @relation(fields: [installment_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([order_id])
  @@index([installment_id])
  @@index([status])
  @@index([transaction_ref])
  @@map("payment_transactions")
}

// ==============================================================================
// updated
model InstallmentPlan {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order_id String @unique

  total_amount Decimal @db.Decimal(10, 2)
  paid_amount  Decimal @default(0) @db.Decimal(10, 2)
  due_amount   Decimal @default(0) @db.Decimal(10, 2)

  installment_count Int
  interval          InstallmentInterval @default(MONTHLY)

  start_date    DateTime
  end_date      DateTime?
  next_due_date DateTime?

  status InstallmentPlanStatus @default(ACTIVE)

  stripe_subscription_id String? @unique

  order        Order         @relation(fields: [order_id], references: [id], onDelete: Cascade)
  installments Installment[]

  @@index([status])
  @@index([next_due_date])
  @@map("installment_plans")
}

// updated
model Installment {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  installment_plan_id String

  installment_no Int
  amount         Decimal @db.Decimal(10, 2)

  due_date DateTime

  status InstallmentStatus @default(PENDING)

  paid_at DateTime?

  installment_plan InstallmentPlan      @relation(fields: [installment_plan_id], references: [id], onDelete: Cascade)
  transactions     PaymentTransaction[]

  @@unique([installment_plan_id, installment_no])
  @@index([installment_plan_id])
  @@index([status])
  @@index([due_date])
  @@map("installments")
}

// updated
enum OrderStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  PAYMENT_FAILED
  CANCELLED
  REFUNDED
}

// updated
model Order {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order_number String @unique

  user_id String

  item_type    OrderItemType
  payment_mode PaymentMode
  status       OrderStatus   @default(PENDING)

  subtotal_amount Decimal @db.Decimal(10, 2)
  discount_amount Decimal @default(0) @db.Decimal(10, 2)
  total_amount    Decimal @db.Decimal(10, 2)

  paid_amount Decimal @default(0) @db.Decimal(10, 2)
  due_amount  Decimal @default(0) @db.Decimal(10, 2)

  currency String @default("USD")

  course_id String?
  event_id  String?

  notes String?

  created_by_admin_id String?
  admin_note          String?

  user   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [course_id], references: [id], onDelete: SetNull)
  event  Event?  @relation(fields: [event_id], references: [id], onDelete: SetNull)

  enrollment       Enrollment?
  installment_plan InstallmentPlan?
  transactions     PaymentTransaction[]

  event_registrations EventRegistration[]

  @@index([user_id])
  @@index([status])
  @@index([item_type])
  @@index([course_id])
  @@index([event_id])
  @@map("orders")
}
